---
import BaseLayout from "../../components/BaseLayout.astro";
const site = "https://shrinktionary.com";
const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact Shrinktionary",
  url: `${site}/contact/`,
  inLanguage: "en-US",
  isPartOf: { "@type": "WebSite", name: "Shrinktionary", url: site },
  publisher: { "@type": "Organization", name: "shrinkMD Publishing" },
};
const breadcrumbs = [
  { name: "Home", path: "/" },
  { name: "Contact", path: "/contact/" },
];
---
<BaseLayout
  title="Contact | Shrinktionary"
  description="How to reach Shrinktionary about corrections, accessibility, press, or general questions. We can't give personal medical advice. In a crisis, call or text 988."
  canonicalPath="/contact/"
  jsonld={[contactSchema]}
  breadcrumbs={breadcrumbs}
>
  <section class="bg-gradient-to-b from-sky to-white">
    <div class="mx-auto max-w-content px-5 py-16">
      <p class="text-watermelon-bright font-semibold uppercase tracking-widest text-xs">Contact</p>
      <h1 class="font-display text-4xl md:text-5xl font-semibold text-ink mt-2">Get in touch</h1>
      <p class="max-w-prose text-lg text-[#1F2937] mt-4">We read every message. The fastest way to reach us is email.</p>
    </div>
  </section>

  <article class="mx-auto max-w-prose px-5 py-14">
    <div class="rounded-lg bg-neutral border border-[#e2e2e2] p-6">
      <p class="text-xs uppercase tracking-widest text-carbon font-semibold">Email</p>
      <p class="font-display text-2xl text-ink mt-1"><a href="mailto:support@shrinktionary.com" class="hover:text-watermelon">support@shrinktionary.com</a></p>
    </div>

    <div class="prose-body mt-8 max-w-none">
      <h2>What we can help with</h2>
      <p>Corrections or factual concerns about an entry, accessibility issues, press and media questions, and general questions about the site or The Shrink Network. If you're reporting a correction, including the page link and what you noticed helps us fix it faster. You can read how we handle changes on our <a href="/corrections/">corrections</a> page.</p>

      <h2>What we can't help with</h2>
      <p>Shrinktionary is an educational publisher, not a clinic. We can't answer personal medical questions, give individual advice, diagnose, or recommend treatment by email, and reading our replies doesn't create a doctor-patient relationship. For questions about your own care, talk to a licensed clinician who knows your situation. If you're looking for care, start with <a href="https://shrinkmd.com/" target="_blank" rel="noopener noreferrer">shrinkMD</a>.</p>

      <h2>If you're in crisis</h2>
      <p>Shrinktionary isn't a crisis service. If you're in crisis or feel unsafe, call or text <a href="tel:988" class="text-watermelon font-semibold">988</a> in the United States to reach the Suicide and Crisis Lifeline, call <a href="tel:911" class="text-watermelon font-semibold">911</a>, or go to the nearest emergency room. See our <a href="/crisis-resources/">crisis resources</a> for more.</p>

      <h2>Publisher</h2>
      <p>Shrinktionary is published by shrinkMD Publishing and is part of The Shrink Network. Mailing address: 8 The Green, STE B, Dover, Delaware 19901, United States.</p>
    </div>
  </article>
</BaseLayout>
