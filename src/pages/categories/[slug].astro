---
import { getCollection } from "astro:content";
import BaseLayout from "../../components/BaseLayout.astro";

export async function getStaticPaths() {
  const categories = await getCollection("categories");
  return categories.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const c = entry.data;

const allTerms = await getCollection("terms");
const allCategories = (await getCollection("categories")).sort((a, b) => a.data.order - b.data.order);
const countFor = (slug: string) => allTerms.filter((t) => t.data.category === slug).length;
const terms = allTerms
  .filter((t) => t.data.category === c.slug)
  .sort((a, b) => a.data.term.localeCompare(b.data.term));


const site = "https://shrinktionary.com";
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `${c.name} | Shrinktionary`,
  description: c.description,
  url: `${site}/categories/${c.slug}/`,
  inLanguage: "en-US",
  isPartOf: { "@type": "WebSite", name: "Shrinktionary", url: site },
  about: { "@type": "Thing", name: c.name },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: terms.map((t, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `${site}/terms/${t.data.slug}/`,
      name: t.data.term,
    })),
  },
};
const breadcrumbs = [
  { name: "Home", path: "/" },
  { name: "Categories", path: "/categories/" },
  { name: c.name, path: `/categories/${c.slug}/` },
];
---
<BaseLayout
  title={`${c.name}: mental health terms | Shrinktionary`}
  description={c.description}
  canonicalPath={`/categories/${c.slug}/`}
  breadcrumbs={breadcrumbs}
  jsonld={[collectionSchema]}
  keywords={[c.name, `${c.name} terms`, "mental health dictionary", "mental health definitions"]}
>
  <section class="bg-sky">
    <div class="mx-auto max-w-content px-5 py-14">
      <nav aria-label="Breadcrumb" class="caption text-[#4B5563] mb-4">
        <a href="/" class="hover:text-watermelon">Home</a> · <a href="/categories/" class="hover:text-watermelon">Categories</a>
      </nav>
      <h1 class="font-display text-4xl font-semibold text-ink">{c.name}</h1>
      <p class="max-w-prose text-[#1F2937] mt-3">{c.long_description}</p>
      <p class="caption text-[#4B5563] mt-3">{terms.length} {terms.length === 1 ? "term" : "terms"}</p>
    </div>
  </section>

  <div class="mx-auto max-w-content px-5 py-12">
    {terms.length > 0 ? (
      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {terms.map((t) => (
          <li>
            <a href={`/terms/${t.data.slug}/`} class="block rounded-md bg-white border border-neutral hover:border-watermelon shadow-sm hover:shadow-md transition p-5 h-full">
              <h2 class="font-display text-lg font-semibold text-ink mb-1">{t.data.term}</h2>
              <p class="text-[15px] text-[#4B5563] line-clamp-3">{t.data.short_definition}</p>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <div>
        <div class="rounded-xl bg-sky/60 border border-neutral p-6 md:p-8">
          <h2 class="font-display text-2xl font-semibold text-ink">What belongs in {c.name}</h2>
          <p class="text-[#1F2937] mt-3 max-w-prose">{c.long_description} As the dictionary grows, the entries in this category will appear here, each one written in plain English and reviewed by a board certified psychiatrist.</p>
          <div class="flex flex-wrap gap-4 mt-6">
            <a href="/terms/" class="inline-flex items-center rounded-md bg-watermelon text-white font-medium px-6 py-3 hover:opacity-90">Browse the full dictionary</a>
            <a href="/start-here/" class="text-[15px] font-medium text-watermelon">Find a word by where you're starting &rarr;</a>
          </div>
        </div>

        <h2 class="font-display text-2xl font-semibold text-ink mt-12 mb-5">Explore another category</h2>
        <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {allCategories.filter((x) => x.data.slug !== c.slug).map((x) => (
            <li>
              <a href={`/categories/${x.data.slug}/`} class="block rounded-md bg-neutral hover:bg-sky border border-transparent hover:border-watermelon transition p-5 h-full">
                <div class="flex items-center justify-between mb-1">
                  <h3 class="font-display text-lg font-semibold text-ink">{x.data.name}</h3>
                  <span class="text-sm text-carbon">{countFor(x.data.slug)} {countFor(x.data.slug) === 1 ? "term" : "terms"}</span>
                </div>
                <p class="text-[15px] text-[#4B5563]">{x.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</BaseLayout>
