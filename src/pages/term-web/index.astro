  ]},
  { label: "Bipolar", steps: [
    { label: "Mania", href: "/terms/mania/" },
    { label: "Hypomania", href: "/terms/hypomania/" },
    { label: "Bipolar disorder", href: "/terms/bipolar-disorder/" },
    { label: "Mood stabilizer", href: "/terms/mood-stabilizer/" },
    { label: "Lithium", href: "/terms/lithium/" },
    { label: "shrinkMD", href: "https://shrinkmd.com/", external: true },
  ]},
  { label: "OCD", steps: [
    { label: "Intrusive thought", href: "/terms/intrusive-thought/" },
