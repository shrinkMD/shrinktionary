---
import { getCollection } from "astro:content";
import BaseLayout from "../../components/BaseLayout.astro";

const site = "https://shrinktionary.com";
const termList = await getCollection("terms");
const categoryList = (await getCollection("categories")).sort((a, b) => a.data.order - b.data.order);
const termSlugs = new Set(termList.map((t) => t.data.slug));
const usedCats = new Set(termList.map((t) => t.data.category));

const catColors: Record<string, string> = {
  symptoms: "#2563EB",
  conditions: "#7C3AED",
  medications: "#059669",
  "therapy-terms": "#D97706",
  "psychiatry-terms": "#0891B2",
  "psychology-terms": "#DB2777",
  "brain-body-terms": "#B45309",
  "everyday-language": "#4F46E5",
  "research-terms": "#65A30D",
};

const netMeta: Record<string, { label: string; url: string }> = {
  shrinkopedia: { label: "Shrinkopedia", url: "https://shrinkopedia.com/" },
  anxietyresource: { label: "AnxietyResource", url: "https://anxietyresource.org/" },
  depressionresource: { label: "DepressionResource", url: "https://depressionresource.org/" },
  psychiatryrx: { label: "PsychiatryRx", url: "https://psychiatryrx.org/" },
  anxietyresearch: { label: "AnxietyResearch", url: "https://anxietyresearch.org/" },
  shrinq: { label: "shrinQ", url: "https://shrinq.com/" },
  unstuck: { label: "Unstuck", url: "https://beunstuck.app/" },
  shrinkmd: { label: "shrinkMD", url: "https://shrinkmd.com/" },
};

type Node = { id: string; label: string; type: "term" | "category" | "network"; category?: string; url: string };
const nodes: Node[] = [];
const seen = new Set<string>();
const addNode = (n: Node) => { if (!seen.has(n.id)) { seen.add(n.id); nodes.push(n); } };
const rawLinks: { source: string; target: string }[] = [];

for (const c of categoryList) {
  if (usedCats.has(c.data.slug)) {
    addNode({ id: `cat:${c.data.slug}`, label: c.data.name, type: "category", category: c.data.slug, url: `/categories/${c.data.slug}/` });
  }
}
for (const t of termList) {
  const d = t.data;
  addNode({ id: d.slug, label: d.term, type: "term", category: d.category, url: `/terms/${d.slug}/` });
  rawLinks.push({ source: d.slug, target: `cat:${d.category}` });
  for (const r of d.related_terms ?? []) if (termSlugs.has(r)) rawLinks.push({ source: d.slug, target: r });
  for (const nl of d.network_links ?? []) {
    const m = netMeta[nl.site];
    if (m) { addNode({ id: `net:${nl.site}`, label: m.label, type: "network", url: m.url }); rawLinks.push({ source: d.slug, target: `net:${nl.site}` }); }
  }
}
const linkSet = new Set<string>();
const links: { source: string; target: string }[] = [];
for (const l of rawLinks) {
  const k = [l.source, l.target].sort().join("|");
  if (!linkSet.has(k) && l.source !== l.target) { linkSet.add(k); links.push(l); }
}
const graph = { nodes, links, colors: catColors };

const pathways = [
  { label: "Anxiety", steps: [
    { label: "Anxiety", href: "/terms/anxiety/" },
    { label: "Hypervigilance", href: "/terms/hypervigilance/" },
    { label: "Avoidance", href: "/terms/avoidance/" },
    { label: "Exposure therapy", href: "/terms/exposure-therapy/" },
    { label: "AnxietyResource", href: "https://anxietyresource.org/", external: true },
    { label: "shrinkMD", href: "https://shrinkmd.com/", external: true },
  ]},
  { label: "Panic", steps: [
    { label: "Panic attack", href: "/terms/panic-attack/" },
    { label: "Hyperventilation", href: "/terms/hyperventilation/" },
    { label: "Panic disorder", href: "/terms/panic-disorder/" },
    { label: "CBT", href: "/terms/cbt/" },
    { label: "shrinkMD", href: "https://shrinkmd.com/", external: true },
  ]},
  { label: "Health anxiety", steps: [
    { label: "Illness anxiety disorder", href: "/terms/illness-anxiety-disorder/" },
    { label: "Catastrophizing", href: "/terms/catastrophizing/" },
    { label: "Rumination", href: "/terms/rumination/" },
    { label: "CBT", href: "/terms/cbt/" },
    { label: "shrinkMD", href: "https://shrinkmd.com/", external: true },
  ]},
  { label: "Depression", steps: [
    { label: "Depression", href: "/terms/depression/" },
    { label: "Anhedonia", href: "/terms/anhedonia/" },
