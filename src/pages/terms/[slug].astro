---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../components/BaseLayout.astro";
import MedicalReviewByline from "../../components/MedicalReviewByline.astro";
import Disclaimer from "../../components/Disclaimer.astro";
import NetworkStrip from "../../components/NetworkStrip.astro";

export async function getStaticPaths() {
  const terms = await getCollection("terms");
  return terms.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const faqEntries = await getCollection("faqs");
const faqEntry = faqEntries.find((e) => e.data.slug === entry.data.slug);
const faqs = faqEntry?.data.faqs ?? [];
const faqSchema =
  faqs.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faqs.map((fq) => ({
          "@type": "Question",
          name: fq.q,
          acceptedAnswer: { "@type": "Answer", text: fq.a },
        })),
      }
    : null;
const d = entry.data;

const site = "https://shrinktionary.com";
const categories = await getCollection("categories");
const category = categories.find((c) => c.data.slug === d.category);
const categoryName = category?.data.name ?? d.category;

const terms = await getCollection("terms");
const bySlug = new Map(terms.map((t) => [t.data.slug, t.data.term]));
const relatedExisting = (d.related_terms ?? []).filter((s) => bySlug.has(s));

const truncate = (str, n) => {
  const v = (str || "").trim();
  if (v.length <= n) return v;
  const cut = v.slice(0, n - 1);
  const i = cut.lastIndexOf(" ");
  return (i > 80 ? cut.slice(0, i) : cut).replace(/[\s,;:.]+$/, "") + "\u2026";
};
const metaDescription = truncate(d.short_definition, 158);

const comparisons = await getCollection("comparisons");
const relatedComparisons = comparisons.filter(
  (cmp) =>
    (cmp.data.terms || []).some((tt) => tt.slug === d.slug) ||
    (cmp.data.related_terms || []).includes(d.slug)
);
const extraEntries = await getCollection("termextra");
const extra = extraEntries.find((e) => e.data.slug === d.slug)?.data;
const confusedWith = extra?.confused_with ?? [];
const whenItMatters = extra?.when_it_matters ?? "";

const toc = headings.filter((h) => h.depth === 2);

const keywords = [
  d.term,
  ...(d.also_known_as ?? []),
  `${d.term} definition`,
  `${d.term} meaning`,
  "mental health",
  categoryName,
];

const medicalWebPageSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  name: d.term,
  description: d.short_definition,
  url: `${site}/terms/${d.slug}/`,
  inLanguage: "en-US",
  datePublished: d.published,
  dateModified: d.last_reviewed,
  lastReviewed: d.last_reviewed,
  mainContentOfPage: { "@type": "WebPageElement", cssSelector: ".term-body" },
  isPartOf: { "@type": "WebSite", name: "Shrinktionary", url: site },
  reviewedBy: {
    "@type": "Person",
    name: "Shariq Refai, MD, MBA, FAPA",
    honorificSuffix: "MD, MBA, FAPA",
    jobTitle: "Board Certified Psychiatrist",
    sameAs: [
      "https://www.wikidata.org/wiki/Q139822307",
      "https://orcid.org/0009-0009-1090-4373",
      "https://shariqrefai.com",
    ],
  },
  author: {
    "@type": "Person",
    name: "Shariq Refai, MD, MBA, FAPA",
    url: "https://shariqrefai.com",
  },
  publisher: {
    "@type": "Organization",
    name: "shrinkMD Publishing",
    logo: { "@type": "ImageObject", url: `${site}/favicon-512.png` },
  },
  citation: d.sources.map((s) => ({
    "@type": "CreativeWork",
    name: s.title,
    publisher: s.publisher,
    url: s.url,
  })),
  about: {
    "@type": "DefinedTerm",
    name: d.term,
    description: d.short_definition,
    inDefinedTermSet: `${site}/terms/`,
    termCode: d.slug,
  },
};

const breadcrumbs = [
  { name: "Home", path: "/" },
  { name: "Glossary", path: "/terms/" },
  { name: categoryName, path: `/categories/${d.category}/` },
  { name: d.term, path: `/terms/${d.slug}/` },
];
---

<BaseLayout
  title={`${d.term} | Shrinktionary`}
  description={metaDescription}
  canonicalPath={`/terms/${d.slug}/`}
  ogType="article"
  jsonld={faqSchema ? [medicalWebPageSchema, faqSchema] : [medicalWebPageSchema]}
  breadcrumbs={breadcrumbs}
  published={d.published}
  modified={d.last_reviewed}
  keywords={keywords}
>
  <div class="reading-progress" id="reading-progress"></div>
  <div class="mx-auto max-w-content px-5 pt-10">
    <nav aria-label="Breadcrumb" class="caption text-carbon mb-5 text-sm">
      <a href="/" class="hover:text-watermelon">Home</a> <span aria-hidden="true">/</span>
      <a href="/terms/" class="hover:text-watermelon">Glossary</a> <span aria-hidden="true">/</span>
      <a href={`/categories/${d.category}/`} class="hover:text-watermelon">{categoryName}</a>
    </nav>

    <p class="text-watermelon font-semibold uppercase tracking-widest text-xs">{categoryName}</p>
    <h1 class="font-display text-4xl md:text-5xl font-semibold text-ink mt-2">{d.term}</h1>
    <p class="text-lg md:text-xl text-[#1F2937] mt-4 max-w-prose">{d.short_definition}</p>
    {d.also_known_as && d.also_known_as.length > 0 ? (
      <p class="text-sm text-carbon mt-3">Also known as: {d.also_known_as.join(", ")}</p>
    ) : null}
    <div class="mt-5 pb-6 border-b border-neutral">
      <MedicalReviewByline lastReviewed={d.last_reviewed} />
    </div>
  </div>

  <div class="mx-auto max-w-content px-5 py-10 grid lg:grid-cols-[minmax(0,1fr)_17rem] gap-10 lg:gap-14 items-start">
    <article class="min-w-0">
      <div class="prose-body term-body max-w-none">
        <Content />
      </div>

      {whenItMatters ? (
        <section class="mt-10 rounded-lg bg-sky/60 border border-neutral p-5 md:p-6">
          <h2 class="font-display text-lg font-semibold text-ink mb-2">When this word matters</h2>
          <p class="text-[#1F2937]">{whenItMatters}</p>
        </section>
      ) : null}

      {confusedWith.length > 0 ? (
        <section class="mt-10">
          <h2 class="font-display text-xl font-semibold text-ink mb-3">Commonly confused with</h2>
          <div class="flex flex-wrap gap-2">
            {confusedWith.map((c) => (
              c.slug && bySlug.has(c.slug)
                ? <a href={`/terms/${c.slug}/`} class="inline-flex rounded-full bg-neutral hover:bg-sky px-4 py-2 text-sm font-medium">{c.label}</a>
                : <span class="inline-flex rounded-full bg-neutral px-4 py-2 text-sm font-medium text-[#4B5563]">{c.label}</span>
            ))}
          </div>
        </section>
      ) : null}

      {faqs.length > 0 ? (
        <section class="mt-12">
          <h2 class="font-display text-xl font-semibold text-ink mb-4">Frequently asked questions</h2>
          <div class="space-y-3">
            {faqs.map((fq) => (
              <details class="group rounded-lg bg-neutral border border-[#e2e2e2] p-5">
                <summary class="flex items-center justify-between cursor-pointer font-semibold text-ink list-none gap-4">
                  {fq.q}
                  <span class="text-watermelon text-2xl leading-none group-open:rotate-45 transition-transform" aria-hidden="true">+</span>
                </summary>
                <p class="text-[#1F2937] mt-3">{fq.a}</p>
              </details>
            ))}
          </div>
        </section>
      ) : null}

      {relatedExisting.length > 0 ? (
        <section class="mt-12">
          <h2 class="font-display text-xl font-semibold text-ink mb-3">Related terms</h2>
          <div class="flex flex-wrap gap-2">
            {relatedExisting.map((s) => (
              <a href={`/terms/${s}/`} class="inline-flex rounded-full bg-neutral hover:bg-sky px-4 py-2 text-sm font-medium">{bySlug.get(s)}</a>
            ))}
          </div>
        </section>
      ) : null}

      {relatedComparisons.length > 0 ? (
        <section class="mt-12">
          <h2 class="font-display text-xl font-semibold text-ink mb-3">Compare</h2>
          <ul class="space-y-2">
            {relatedComparisons.map((cmp) => (
              <li>
                <a href={`/compare/${cmp.data.slug}/`} class="inline-flex items-center gap-2 text-[15px] font-medium text-watermelon hover:text-ink">
                  {cmp.data.title}
                  <span aria-hidden="true">&rarr;</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ) : null}

      <section class="mt-12">
        <h2 class="font-display text-xl font-semibold text-ink mb-3">Sources</h2>
        <ol class="space-y-2 list-decimal pl-5">
          {d.sources.map((s) => (
            <li class="text-[15px]">
              <a href={s.url} target="_blank" rel="noopener noreferrer" class="text-watermelon underline underline-offset-2">{s.title}</a>
              <span class="text-[#4B5563]">, {s.publisher}</span>
            </li>
          ))}
        </ol>
      </section>

      <div class="mt-12">
        <NetworkStrip links={d.network_links} />
      </div>
      <div class="mt-10">
        <Disclaimer />
      </div>
    </article>

    <aside class="hidden lg:block sticky top-28 self-start">
      {toc.length > 0 ? (
        <nav aria-label="On this page" class="mb-8">
          <p class="text-xs uppercase tracking-widest text-carbon font-semibold mb-3 flex items-center gap-2"><span class="inline-block w-3 h-[2px] bg-watermelon"></span>On this page</p>
          <ul class="space-y-2 border-l border-neutral">
            {toc.map((h) => (
              <li><a href={`#${h.slug}`} class="toc-link block pl-4 -ml-px border-l-2 border-transparent hover:border-watermelon text-sm text-[#4B5563] hover:text-watermelon">{h.text}</a></li>
            ))}
          </ul>
        </nav>
      ) : null}

      <div class="rounded-lg bg-neutral p-5">
        <p class="text-xs uppercase tracking-widest text-carbon font-semibold mb-3">Key facts</p>
        <dl class="space-y-3 text-sm">
          <div>
            <dt class="text-carbon">Category</dt>
            <dd><a href={`/categories/${d.category}/`} class="font-medium text-ink hover:text-watermelon">{categoryName}</a></dd>
          </div>
          {d.also_known_as && d.also_known_as.length > 0 ? (
            <div>
              <dt class="text-carbon">Also known as</dt>
              <dd class="font-medium text-ink">{d.also_known_as.join(", ")}</dd>
            </div>
          ) : null}
          <div>
            <dt class="text-carbon">Medically reviewed by</dt>
            <dd><a href="/medical-review/" class="font-medium text-ink hover:text-watermelon">Shariq Refai, MD, MBA, FAPA</a></dd>
          </div>
          <div>
            <dt class="text-carbon">Last reviewed</dt>
            <dd class="font-medium text-ink">{d.last_reviewed}</dd>
          </div>
          <div>
            <dt class="text-carbon">Sources</dt>
            <dd class="font-medium text-ink">{d.sources.length} cited</dd>
          </div>
        </dl>
      </div>
    </aside>
  </div>

<script is:inline>
  (function () {
    var bar = document.getElementById("reading-progress");
    function prog() {
      if (!bar) return;
      var h = document.documentElement;
      var max = h.scrollHeight - h.clientHeight;
      bar.style.width = (max > 0 ? (h.scrollTop / max) * 100 : 0) + "%";
    }
    prog();
    window.addEventListener("scroll", prog, { passive: true });
    window.addEventListener("resize", prog);
    var links = [].slice.call(document.querySelectorAll(".toc-link"));
    if (links.length && "IntersectionObserver" in window) {
      var map = {};
      links.forEach(function (a) {
        var id = (a.getAttribute("href") || "").slice(1);
        var el = id && document.getElementById(id);
        if (el) map[id] = a;
      });
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            links.forEach(function (l) { l.classList.remove("is-active"); });
            if (map[e.target.id]) map[e.target.id].classList.add("is-active");
          }
        });
      }, { rootMargin: "-20% 0px -70% 0px", threshold: 0 });
      Object.keys(map).forEach(function (id) {
        var el = document.getElementById(id);
        if (el) obs.observe(el);
      });
    }
  })();
</script>
</BaseLayout>
