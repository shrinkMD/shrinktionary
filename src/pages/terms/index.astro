---
import { getCollection } from "astro:content";
import BaseLayout from "../../components/BaseLayout.astro";
import SearchBox from "../../components/SearchBox.astro";

const terms = (await getCollection("terms")).sort((a, b) => a.data.term.localeCompare(b.data.term));
const categories = (await getCollection("categories")).sort((a, b) => a.data.order - b.data.order);
const catName = new Map(categories.map((c) => [c.data.slug, c.data.name]));


const definedTermSetSchema = {
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  "@id": "https://shrinktionary.com/terms/",
  name: "Shrinktionary Mental Health Glossary",
  description: "A plain-English glossary of mental health and psychiatry: symptoms, conditions, medications, and therapy terms, medically reviewed by a board certified psychiatrist.",
  url: "https://shrinktionary.com/terms/",
  inLanguage: "en-US",
  hasDefinedTerm: terms.map((t) => ({
    "@type": "DefinedTerm",
    name: t.data.term,
    description: t.data.short_definition,
    url: `https://shrinktionary.com/terms/${t.data.slug}/`,
    termCode: t.data.slug,
  })),
};
const breadcrumbs = [
  { name: "Home", path: "/" },
  { name: "Glossary", path: "/terms/" },
];
---
<BaseLayout
  title="Mental Health Glossary, A to Z | Shrinktionary"
  description="A plain-English glossary of mental health and psychiatry terms, A to Z. Definitions of symptoms, conditions, medications, and therapy words, reviewed by a psychiatrist."
  canonicalPath="/terms/"
  breadcrumbs={breadcrumbs}
  jsonld={[definedTermSetSchema]}
  keywords={["mental health glossary","glossary of psychiatry","mental health terminology","psychiatry terms","mental health dictionary","mental health definitions","important mental health words"]}
>
  <section class="bg-sky">
    <div class="mx-auto max-w-content px-5 py-14">
      <p class="caption text-[#4B5563] uppercase tracking-widest text-xs">Glossary</p>
      <h1 class="font-display text-4xl font-semibold text-ink mt-2">Mental health glossary</h1>
      <p class="max-w-prose text-[#1F2937] mt-3">A plain-English glossary of mental health and psychiatry: {terms.length} terms covering symptoms, conditions, medications, therapy concepts, and the everyday words people get stuck on. Every entry is medically reviewed by a board certified psychiatrist.</p>
      <p class="max-w-prose text-[#1F2937] mt-3">These are the words you'll meet in an appointment, on a form, or in something you read about your own mental health. Look one up below, or browse <a href="/categories/" class="text-watermelon underline underline-offset-2 hover:text-ink">by category</a> or <a href="/clusters/" class="text-watermelon underline underline-offset-2 hover:text-ink">by language cluster</a> to learn the words in context.</p>
      <div class="max-w-xl mt-6"><SearchBox id="terms-search" placeholder="Search the glossary" /></div>
    </div>
  </section>

  <div class="mx-auto max-w-content px-5 py-10">
    <div class="flex flex-wrap gap-2 mb-8" data-filters>
      <button class="chip rounded-full border border-carbon px-4 py-1.5 text-sm font-medium hover:border-watermelon hover:text-watermelon" data-cat="all" aria-pressed="true">All</button>
      {categories.map((c) => (
        <button class="chip rounded-full border border-carbon px-4 py-1.5 text-sm font-medium hover:border-watermelon hover:text-watermelon" data-cat={c.data.slug} aria-pressed="false">{c.data.name}</button>
      ))}
    </div>

    <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" data-term-list>
      {terms.map((t) => (
        <li data-category={t.data.category}>
          <a href={`/terms/${t.data.slug}/`} class="block rounded-md bg-white border border-neutral hover:border-watermelon shadow-sm hover:shadow-md transition p-5 h-full">
            <div class="flex items-center justify-between mb-1">
              <h2 class="font-display text-lg font-semibold text-ink">{t.data.term}</h2>
              <span class="caption text-carbon">{catName.get(t.data.category)}</span>
            </div>
            <p class="text-[15px] text-[#4B5563] line-clamp-3">{t.data.short_definition}</p>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <script>
