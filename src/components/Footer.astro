---
const understand = [
  { label: "Shrinkopedia", href: "https://shrinkopedia.com/" },
  { label: "Shrinktionary", href: "/", current: true },
  { label: "AnxietyResource", href: "https://anxietyresource.org/" },
  { label: "DepressionResource", href: "https://depressionresource.org/" },
  { label: "AnxietyResearch", href: "https://anxietyresearch.org/" },
  { label: "PsychiatryRx", href: "https://psychiatryrx.org/" },
];
const apply = [
  { label: "shrinQ", href: "https://shrinq.com/" },
  { label: "Unstuck", href: "https://beunstuck.app/" },
  { label: "QuitScrolling", href: "https://quitscrolling.app/" },
];
const care = [{ label: "shrinkMD", href: "https://shrinkmd.com/" }];
const profession = [
  { label: "shrinkiatry", href: "https://shrinkiatry.com/" },
  { label: "Shariq Refai", href: "https://shariqrefai.com/" },
];
const editorial = [
  { label: "About", href: "/about/" },
  { label: "Editorial standards", href: "/editorial-standards/" },
  { label: "Medical review", href: "/medical-review/" },
  { label: "Sources", href: "/sources/" },
  { label: "Corrections", href: "/corrections/" },
  { label: "Sitemap", href: "/sitemap/" },
  { label: "Contact", href: "/contact/" },
];
const legal = [
  { label: "Medical disclaimer", href: "/disclaimer/" },
  { label: "Privacy policy", href: "/privacy/" },
  { label: "Terms of use", href: "/terms-of-use/" },
  { label: "Accessibility", href: "/accessibility/" },
  { label: "AI use", href: "/ai-use/" },
  { label: "Disclosures", href: "/disclosures/" },
  { label: "Crisis resources", href: "/crisis-resources/" },
];
const ext = (h: string) => h.startsWith("http");
---

<footer class="bg-ink text-white mt-24 border-t-4 border-watermelon-bright">
  <div class="mx-auto max-w-content px-5 py-16">

    <!-- Top band -->
    <div class="pb-10 border-b border-white/10">
      <div class="inline-flex flex-col leading-none">
        <span class="font-display text-3xl font-semibold text-white">Shrinktionary</span>
        <span class="h-[3px] w-12 bg-watermelon-bright mt-2 rounded-full"></span>
      </div>
      <p class="text-watermelon-bright font-semibold tracking-widest text-xs uppercase mt-5">Part of the Shrink Network</p>
      <p class="font-display text-xl text-white mt-1">Shrinktionary is the language layer of The Shrink Network.</p>
      <p class="text-white/60 text-sm max-w-2xl mt-2">A plain-English mental health dictionary, written and medically reviewed by a board certified psychiatrist. Education, not medical advice.</p>
    </div>

    <!-- Crisis callout -->
    <div class="mt-8 rounded-lg bg-white/[0.04] border border-white/10 border-l-4 border-l-watermelon-bright px-5 py-4">
      <p class="text-sm text-white/85 leading-relaxed">
        <span class="font-semibold text-watermelon-bright">In crisis or feel unsafe?</span>
        Call or text <a href="tel:988" class="font-semibold text-watermelon-bright underline underline-offset-2 hover:text-white">988</a>,
        call <a href="tel:911" class="font-semibold text-watermelon-bright underline underline-offset-2 hover:text-white">911</a>,
        or go to the nearest emergency room.
        <a href="/crisis-resources/" class="font-semibold text-watermelon-bright underline underline-offset-2 hover:text-white">See crisis resources &rarr;</a>
      </p>
    </div>

    <!-- Network family -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-x-8 gap-y-10 mt-12">
      <div>
        <h3 class="flex items-center gap-2 text-white/50 text-xs uppercase tracking-widest mb-4"><span class="inline-block w-3 h-[2px] bg-watermelon-bright"></span>Understand</h3>
        <ul class="space-y-2.5">
          {understand.map((l) => (
            <li><a href={l.href} target={ext(l.href) ? "_blank" : undefined} rel={ext(l.href) ? "noopener noreferrer" : undefined} class="text-sm text-white/85 hover:text-watermelon-bright">{l.label}{l.current ? " (current)" : ""}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="flex items-center gap-2 text-white/50 text-xs uppercase tracking-widest mb-4"><span class="inline-block w-3 h-[2px] bg-watermelon-bright"></span>Apply</h3>
        <ul class="space-y-2.5">
          {apply.map((l) => (<li><a href={l.href} target="_blank" rel="noopener noreferrer" class="text-sm text-white/85 hover:text-watermelon-bright">{l.label}</a></li>))}
        </ul>
      </div>
      <div>
        <h3 class="flex items-center gap-2 text-white/50 text-xs uppercase tracking-widest mb-4"><span class="inline-block w-3 h-[2px] bg-watermelon-bright"></span>Care</h3>
        <ul class="space-y-2.5">
          {care.map((l) => (<li><a href={l.href} target="_blank" rel="noopener noreferrer" class="text-sm text-white/85 hover:text-watermelon-bright">{l.label}</a></li>))}
        </ul>
      </div>
      <div>
        <h3 class="flex items-center gap-2 text-white/50 text-xs uppercase tracking-widest mb-4"><span class="inline-block w-3 h-[2px] bg-watermelon-bright"></span>Profession</h3>
        <ul class="space-y-2.5">
          {profession.map((l) => (<li><a href={l.href} target="_blank" rel="noopener noreferrer" class="text-sm text-white/85 hover:text-watermelon-bright">{l.label}</a></li>))}
        </ul>
      </div>
    </div>

    <!-- Editorial + Legal -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-10 mt-10 pt-10 border-t border-white/10">
      <div>
        <h3 class="flex items-center gap-2 text-white/50 text-xs uppercase tracking-widest mb-4"><span class="inline-block w-3 h-[2px] bg-watermelon-bright"></span>Editorial</h3>
        <ul class="space-y-2.5">
          {editorial.map((l) => (<li><a href={l.href} class="text-sm text-white/85 hover:text-watermelon-bright">{l.label}</a></li>))}
        </ul>
      </div>
      <div class="md:col-span-2">
        <h3 class="flex items-center gap-2 text-white/50 text-xs uppercase tracking-widest mb-4"><span class="inline-block w-3 h-[2px] bg-watermelon-bright"></span>Legal</h3>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-2.5">
          {legal.map((l) => (<li><a href={l.href} class="text-sm text-white/85 hover:text-watermelon-bright">{l.label}</a></li>))}
        </ul>
      </div>
    </div>

    <!-- Disclosure -->
    <p class="text-white/55 text-sm mt-12 pt-8 border-t border-white/10 max-w-3xl leading-relaxed">
      Shrinktionary is the language layer of The Shrink Network, a family of independent mental health properties founded and medically reviewed by Shariq Refai, MD, MBA. Clinical care, education, wellness, and publishing are kept operationally separate, and none of these properties run advertising or earn referral revenue.
    </p>

    <!-- Bottom bar -->
    <div class="mt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <p class="text-white/50 text-sm">&copy; 2026 Shrinktionary. The language layer of The Shrink Network.</p>
      <p class="text-white/50 text-sm">Education, not medical advice.</p>
    </div>
  </div>
</footer>
