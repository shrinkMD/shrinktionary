---
const understand = [
  { label: "Shrinkopedia", href: "https://shrinkopedia.com/" },
  { label: "Shrinktionary", href: "/", current: true },
  { label: "AnxietyResource", href: "https://anxietyresource.org/" },
  { label: "DepressionResource", href: "https://depressionresource.org/" },
  { label: "AnxietyResearch", href: "https://anxietyresearch.org/" },
  { label: "PsychiatryRx", href: "https://psychiatryrx.org/" },
];
const apply = [
  { label: "shrinQ", href: "https://shrinq.com/" },
  { label: "Unstuck", href: "https://beunstuck.app/" },
  { label: "QuitScrolling", href: "https://quitscrolling.app/" },
];
const care = [{ label: "shrinkMD", href: "https://shrinkmd.com/" }];
const profession = [
  { label: "shrinkiatry", href: "https://shrinkiatry.com/" },
  { label: "Shariq Refai", href: "https://shariqrefai.com/" },
];

const editorial = [
  { label: "About", href: "/about/" },
  { label: "Editorial standards", href: "/editorial-standards/" },
  { label: "Medical review", href: "/medical-review/" },
  { label: "Sources", href: "/sources/" },
  { label: "Corrections", href: "/corrections/" },
];
const legal = [
  { label: "Medical disclaimer", href: "/disclaimer/" },
  { label: "Privacy policy", href: "/privacy/" },
  { label: "Terms of use", href: "/terms-of-use/" },
  { label: "Accessibility", href: "/accessibility/" },
  { label: "AI use", href: "/ai-use/" },
  { label: "Disclosures", href: "/disclosures/" },
  { label: "Crisis resources", href: "/crisis-resources/" },
];

function ext(href: string) {
  return href.startsWith("http");
}
---

<footer class="bg-ink text-white mt-24">
  <div class="mx-auto max-w-content px-5 py-14">
    <p class="text-watermelon-bright font-semibold tracking-widest text-xs uppercase">Part of the Shrink Network</p>
    <p class="font-display text-xl mt-2 text-white">Shrinktionary is the language layer of The Shrink Network.</p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-10">
      <div>
        <h3 class="text-white/60 text-xs uppercase tracking-widest mb-3">Understand</h3>
        <ul class="space-y-2">
          {understand.map((l) => (
            <li>
              <a href={l.href} target={ext(l.href) ? "_blank" : undefined} rel={ext(l.href) ? "noopener noreferrer" : undefined} class="text-sm text-white/85 hover:text-watermelon-bright">
                {l.label}{l.current ? " (current)" : ""}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-white/60 text-xs uppercase tracking-widest mb-3">Apply</h3>
        <ul class="space-y-2">
          {apply.map((l) => (
            <li><a href={l.href} target="_blank" rel="noopener noreferrer" class="text-sm text-white/85 hover:text-watermelon-bright">{l.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-white/60 text-xs uppercase tracking-widest mb-3">Care</h3>
        <ul class="space-y-2">
          {care.map((l) => (
            <li><a href={l.href} target="_blank" rel="noopener noreferrer" class="text-sm text-white/85 hover:text-watermelon-bright">{l.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-white/60 text-xs uppercase tracking-widest mb-3">Profession</h3>
        <ul class="space-y-2">
          {profession.map((l) => (
            <li><a href={l.href} target="_blank" rel="noopener noreferrer" class="text-sm text-white/85 hover:text-watermelon-bright">{l.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12 pt-10 border-t border-white/15">
      <div>
        <h3 class="text-white/60 text-xs uppercase tracking-widest mb-3">Editorial</h3>
        <ul class="space-y-2">
          {editorial.map((l) => (
            <li><a href={l.href} class="text-sm text-white/85 hover:text-watermelon-bright">{l.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-white/60 text-xs uppercase tracking-widest mb-3">Legal</h3>
        <ul class="space-y-2">
          {legal.map((l) => (
            <li><a href={l.href} class="text-sm text-white/85 hover:text-watermelon-bright">{l.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <p class="text-white/60 text-sm mt-12 max-w-3xl">
      Shrinktionary is the language layer of The Shrink Network, a family of independent mental health properties founded and medically reviewed by Shariq Refai, MD, MBA. Clinical care, education, wellness, and publishing are kept operationally separate, and none of these properties run advertising or earn referral revenue.
    </p>

    <div class="border-t border-white/15 mt-10 pt-6 space-y-2">
      <p class="text-sm text-white/85">Shrinktionary is for general education, not medical advice. If you're in crisis or feel unsafe, call or text <a href="tel:988" class="font-semibold underline underline-offset-2 hover:text-watermelon-bright">988</a>, call <a href="tel:911" class="font-semibold underline underline-offset-2 hover:text-watermelon-bright">911</a>, or go to the nearest emergency room.</p>
      <p class="text-white/55 text-sm">© 2026 Shrinktionary. The language layer of The Shrink Network.</p>
    </div>
  </div>
</footer>
