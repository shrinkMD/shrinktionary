---
const links = [
  { label: "Start Here", href: "/start-here/" },
  { label: "Glossary", href: "/terms/" },
  { label: "Clusters", href: "/clusters/" },
  { label: "Compare", href: "/compare/" },
  { label: "Term Web", href: "/term-web/" },
  { label: "Categories", href: "/categories/" },
  { label: "The Shrink Network", href: "https://shrinknetwork.com/", external: true },
];
const path = Astro.url.pathname;
---

<!-- Crisis bar: present on every page for safety and routing -->
<div class="bg-ink text-white text-[13px]">
  <div class="mx-auto max-w-content px-5 py-2 text-center">
    In crisis or thinking about suicide? Call or text <a href="tel:988" class="font-semibold text-watermelon-bright underline underline-offset-2 hover:text-white">988</a> in the US, available 24 hours a day. If someone is in immediate danger, call <a href="tel:911" class="font-semibold text-watermelon-bright underline underline-offset-2 hover:text-white">911</a>. <a href="/crisis-resources/" class="font-semibold text-watermelon-bright underline underline-offset-2 hover:text-white">Crisis resources</a>
  </div>
</div>

<header id="site-header" class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-neutral">
  <div class="mx-auto max-w-content px-5 flex items-center justify-between h-20">
    <div class="flex flex-col leading-none">
      <a href="/" class="group inline-flex flex-col leading-none">
        <span class="font-display text-2xl font-semibold text-ink">Shrinktionary</span>
        <span class="h-[3px] w-10 bg-watermelon-bright mt-1 rounded-full group-hover:w-full transition-all duration-300"></span>
      </a>
      <a href="https://shrinknetwork.com/" target="_blank" rel="noopener noreferrer" class="text-[11px] uppercase tracking-widest text-carbon hover:text-watermelon mt-1.5">Part of The Shrink Network</a>
    </div>

    <nav aria-label="Primary" class="hidden md:flex items-center gap-6">
      {
        links.map((l) => (
          <a
            href={l.href}
            target={l.external ? "_blank" : undefined}
            rel={l.external ? "noopener noreferrer" : undefined}
            aria-current={path === l.href ? "page" : undefined}
            class={`text-[15px] font-medium hover:text-watermelon transition-colors ${
              path === l.href ? "text-watermelon underline underline-offset-4" : "text-ink"
            }`}
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <button
      id="menu-toggle"
      class="md:hidden inline-flex items-center justify-center w-11 h-11 rounded-md border border-neutral"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>

  <nav id="mobile-menu" aria-label="Mobile" class="md:hidden hidden border-t border-neutral bg-white">
    <div class="mx-auto max-w-content px-5 py-3 flex flex-col gap-3">
      {
        links.map((l) => (
          <a
            href={l.href}
            target={l.external ? "_blank" : undefined}
            rel={l.external ? "noopener noreferrer" : undefined}
            class="text-[15px] font-medium text-ink hover:text-watermelon py-1"
          >
            {l.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(open === false));
  });

  const header = document.getElementById("site-header");
  const onScroll = () => header?.classList.toggle("is-scrolled", window.scrollY > 8);
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
